---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Prześlij se — Bezpieczny transfer P2P / Secure P2P Transfer',
  description = 'Transfer files directly between devices. No server, no account, no upload. Peer-to-peer.',
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen antialiased">
    <slot />
  </body>
</html>
